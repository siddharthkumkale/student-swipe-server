<?xml version="1.0" encoding="utf-8"?>
<!-- Native Android launch screen shown before Flutter renders.
     We use a dark background that matches AppTheme.bgTop and
     center the app launcher icon with comfortable padding. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color (matches AppTheme.bgTop: #0F172A) -->
    <item android:drawable="@android:color/black" />

    <!-- Centered launcher icon -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon" />
    </item>

</layer-list>
